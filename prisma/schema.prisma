// Prisma Schema — Portal Imobiliário Programático
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum PropertyType {
  CASA
  APARTAMENTO
  COBERTURA
  TERRENO
  COMERCIAL
  STUDIO
}

enum TransactionType {
  SALE
  RENT
}

// — Leads: gestão administrativa (não exposto no portal público)
enum LeadOrigin {
  site
  manual
}

enum LeadStatus {
  novo
  em_contato
  qualificado
  vendido
  perdido
}

// ---------------------------------------------------------------------------
// Model Principal
// ---------------------------------------------------------------------------

model Property {
  id String @id @default(cuid())

  // — Identidade e URL canônica
  slug          String  @unique
  title         String
  description   String? @db.Text
  autoGenerated Boolean @default(false)
  externalId    String? @unique // Código externo para importação (evita duplicação)
  oldUrl        String? @db.Text // URL antiga do imóvel (para redirects)

  // — Transação e preço
  transactionType TransactionType
  price           Decimal         @db.Decimal(10, 2)

  // — Localização (labels para exibição)
  city         String
  neighborhood String?
  state        String

  // — Slugs SEO programáticos (indexados individualmente)
  citySlug         String
  neighborhoodSlug String?
  stateSlug        String
  propertyTypeSlug String

  // — Tipologia e características
  type      PropertyType
  bedrooms  Int          @default(0)
  bathrooms Int          @default(0)
  garage    Int          @default(0)
  area      Float?

  // — Mídia
  featuredImage     String?
  featuredImageAlt String?
  galleryImages    String[]
  youtubeVideoId   String?

  // — Dados do proprietário (uso interno, nunca expostos no portal)
  ownerName  String?
  ownerPhone String?

  // — SEO on-page
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  // — Status e visibilidade
  isFeatured   Boolean   @default(false)
  isLaunch     Boolean   @default(false)
  isOpportunity Boolean @default(false)
  isSold       Boolean   @default(false)
  published    Boolean   @default(false)
  publishedAt  DateTime?

  // — Auditoria
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // — Índices estratégicos para SEO programático e feeds
  // slug não precisa de @@index — o @unique já cria índice implícito no PostgreSQL
  @@index([citySlug])
  @@index([neighborhoodSlug])
  @@index([stateSlug])
  @@index([propertyTypeSlug])
  @@index([type, transactionType])
  @@index([published, publishedAt])
  @@index([isFeatured])
  @@index([city, neighborhood])

  // — Galeria de imagens (PropertyImage)
  images PropertyImage[]
}

// ---------------------------------------------------------------------------
// Imagens do imóvel — galeria com metadados
// ---------------------------------------------------------------------------

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  alt        String?
  environment String?
  isPrimary  Boolean  @default(false)
  isHidden   Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

// ---------------------------------------------------------------------------
// Blog editorial — SEO de intenção informacional
// ---------------------------------------------------------------------------

model Post {
  id String @id @default(cuid())

  // — Identidade e URL canônica
  slug    String @unique
  title   String
  excerpt String? @db.Text
  content String  @db.Text

  // — SEO on-page
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  // — Mídia
  featuredImage String?

  // — Cluster SEO: associa o post a entidades programáticas do portal.
  // Convenção de tags:
  //   "cidade:{slug}"  → /cidade/[slug]
  //   "bairro:{slug}"  → /bairro/[slug]
  //   "tipo:{slug}"    → /tipo/[slug]
  // Um post pode ter múltiplas tags (ex: cobre dois tipos de imóvel).
  tags String[] @default([])

  // — Status e visibilidade
  published   Boolean   @default(false)
  publishedAt DateTime?

  // — Auditoria
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // slug @unique já cria índice implícito no PostgreSQL
  @@index([published, publishedAt])
}

// ---------------------------------------------------------------------------
// Leads — gestão administrativa (painel admin, leads do site futuros)
// Não exposto no portal público. Uso exclusivo em /admin.
// ---------------------------------------------------------------------------

model Lead {
  id String @id @default(cuid())

  // — Identificação e contato
  name  String
  phone String

  // — Preferência (string flexível: "até 500k", "300k-600k", etc.)
  desiredPriceRange String?

  // — Origem e workflow
  origin       LeadOrigin
  manualSource String? // "instagram" | "indicacao" quando origin = manual
  status       LeadStatus

  // — Anotações internas
  notes String? @db.Text

  // — Auditoria
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([origin])
  @@index([createdAt])
}
