// Prisma Schema — Portal Imobiliário Programático
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum PropertyType {
  CASA
  APARTAMENTO
  COBERTURA
  TERRENO
  COMERCIAL
  STUDIO
}

enum TransactionType {
  SALE
  RENT
}

// ---------------------------------------------------------------------------
// Model Principal
// ---------------------------------------------------------------------------

model Property {
  id String @id @default(cuid())

  // — Identidade e URL canônica
  slug          String  @unique
  title         String
  description   String? @db.Text
  autoGenerated Boolean @default(false)

  // — Transação e preço
  transactionType TransactionType
  price           Decimal         @db.Decimal(10, 2)

  // — Localização (labels para exibição)
  city         String
  neighborhood String?
  state        String

  // — Slugs SEO programáticos (indexados individualmente)
  citySlug         String
  neighborhoodSlug String?
  stateSlug        String
  propertyTypeSlug String

  // — Tipologia e características
  type      PropertyType
  bedrooms  Int          @default(0)
  bathrooms Int          @default(0)
  garage    Int          @default(0)
  area      Float?

  // — Mídia
  featuredImage  String?
  galleryImages  String[]
  youtubeVideoId String?

  // — SEO on-page
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  // — Status e visibilidade
  isFeatured  Boolean   @default(false)
  isSold      Boolean   @default(false)
  published   Boolean   @default(false)
  publishedAt DateTime?

  // — Auditoria
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // — Índices estratégicos para SEO programático e feeds
  // slug não precisa de @@index — o @unique já cria índice implícito no PostgreSQL
  @@index([citySlug])
  @@index([neighborhoodSlug])
  @@index([stateSlug])
  @@index([propertyTypeSlug])
  @@index([type, transactionType])
  @@index([published, publishedAt])
  @@index([isFeatured])
  @@index([city, neighborhood])
}
